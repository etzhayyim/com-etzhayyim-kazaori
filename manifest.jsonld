  "id": "did:web:kazaori.etzhayyim.com",
  "name": "kazaori",
  "displayName": "風折 — Civilian Disaster Response",
  "displayNameJa": "風折",
  "displayNameEn": "Kazaori",
  "description": "Non-profit religious-corp civilian disaster response substrate. Earthquake / typhoon / flood / wildfire / pandemic / power outage / water shortage / food shortage / building damage / mass evacuation / medical surge coordination. NOT military (G5+N1; force authorization separate per ADR-2605192315). NOT war-zone humanitarian (N2). NO commercial disaster mgmt software (G4: Veoci/NC4/Crisis Track/Everbridge/OnSolve/SAP DR/Microsoft DR Hub/IBM Crisis Response PROHIBITED per Charter Rider §2(e)+§2(c)). NO surveillance (G6: opt-in self-check-in only; aerial drone / facial-recognition / Bluetooth-beacon PROHIBITED per Charter §2(c)). Time-bounded carve-outs (G8: 60-day initial + Council Lv7+ unanimity extension + auto-revoke). Sphere Standards reference (G9). Council Lv6+ ≥4/7 declaration (G10). 6 cells / 6 Lexicons / 12 gates / 12 non-goals.",
  "descriptionJa": "非営利 religious-corp の市民災害対応 substrate。地震 / 台風 / 洪水 / 山火事 / パンデミック / 停電 / 水不足 / 食料不足 / 建物被害 / 集団避難 / 医療サージ調整。軍事ではない(G5+N1; 武力認可は ADR-2605192315 で別)。戦地人道支援ではない(N2)。商業災害管理ソフト禁止(G4: Veoci/NC4/Crisis Track/Everbridge/OnSolve PROHIBITED per Charter Rider §2(e)+§2(c))。監視ベース監視なし(G6: オプトイン自己チェックインのみ; ドローン / 顔認識 / Bluetooth-ビーコン PROHIBITED per Charter §2(c))。時限カーブアウト(G8: 60日初期 + Council Lv7+全会一致延長 + 自動失効)。Sphere Standards 参照(G9)。",
  "adr": {
    "master": "etzhayyim:adr:2605263200",
    "parent": "etzhayyim:adr:2605192100",
    "r0": "etzhayyim:adr:2605263200",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "form": "任意団体 internal civilian disaster response substrate (NOT 一般社団 / NPO / 公益財団 / 宗教法人 法人格 — Preamble §0.4 Lv7+ unanimity lock)",
  "civilianOnlyInvariant": "G5+N1 — kazaori is civilian disaster response only; force authorization separate per ADR-2605192315 Transparent Force; kazaori MUST NOT invoke or coordinate with armed force actions",
  "standardsReferenceNotMembership": [
    "Sphere Standards (G9; reference framework for shelter/water/food/health/protection)",
    "ICRC Code of Conduct for International Red Cross / Red Crescent Movement",
    "IFRC",
    "UN OCHA cluster system",
    "WHO Health Cluster"
  ],
  "crossActor": {
    "mizuho": "G5 single-use container time-bounded carve-out coordination during emergency; emergency water supply dispatch",
    "mitsuho": "Emergency food supply from reserve stocks + mutual aid distribution",
    "hagukumi": "Vulnerable population coordination (children + elderly + chronic care) during evacuation",
    "iyashi": "Clinical capacity surge; clinic-overflow + temporary triage site authorization",
    "mitate": "Diagnostic surge + emergency keyword cross-actor (existing G10 mitate emergency-keyword Lexicon)",
    "tatekata": "Building damage assessment + safe-site designation",
    "hikari": "Power outage coordination + grid-edge battery emergency redirection",
    "chigiri": "Declaration procedural attestation + post-emergency mediation if carve-out cure-period applies",
    "toritate": "Public Fund emergency disbursement + post-emergency accounting transparency",
    "wakai": "(future) Mutual aid pooling across community sites",
    "kokoro": "(future) Post-emergency mental health surge",
    "shidemori": "(future) Mass-fatality memorial when applicable"
  },
  "constitutionalDiscipline": {
    "civilianOnly": "G5+N1 — no armed enforcement; force separate per ADR-2605192315",
    "noCommercialDisasterMgmtSoftware": "G4 — Veoci / NC4 / Crisis Track / Everbridge / OnSolve / SAP Disaster Recovery / Microsoft Disaster Response Hub / IBM Crisis Response PROHIBITED per Charter Rider §2(e)+§2(c)",
    "noSurveillance": "G6 — aerial drone surveillance / facial-recognition crowd-monitoring / Bluetooth-beacon-tracking PROHIBITED per Charter §2(c); evacuation check-in is OPT-IN self-attestation only",
    "timeBoundedCarveOuts": "G8 — normally-prohibited operations (mizuho G5 single-use container etc.) MAY be activated only during Council-Lv6+-declared emergency; 60-day initial / Council Lv7+ unanimity extension / auto-revoke on emergency-lifting; logged via emergencyCarveOutLog",
    "sphereStandardsMinimum": "G9 — open-publication reference framework; silenKazaoriReview audits compliance",
    "councilDeclaration": "G10 — Council Lv6+ ≥4/7 required for emergency state declaration",
    "noPayrollForResponders": "G12 — vocation-flow L5 stewards (cross-actor chigiri + toritate enforcement)",
    "muragumoOnlyInference": "G7 — commercial disaster-AI (One Concern / FloodFlash) PROHIBITED"
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Civilian disaster response coordination for religious-corp community sites + adjacent partner sites",
    "exclusions": [
      "military operations / armed enforcement (force authorization separate ADR-2605192315)",
      "war-zone humanitarian aid",
      "long-term refugee resettlement (≤180 days post-event only)",
      "insurance claim processing",
      "state emergency-management replacement (parallel substrate)",
      "surveillance-based monitoring (opt-in self-check-in only)",
      "commercial disaster management software integration",
      "closed-source firmware / control systems",
      "state-licensed entity status",
      "single-jurisdiction-dependence (community-scale jurisdiction-agnostic)",
      "permanent emergency state (G8 time-bounded)",
      "carve-out normalization (auto-revoke on lifting)"
    ]
  },
