      "G6": "NO surveillance-based monitoring (aerial drone / facial-recognition / Bluetooth-beacon PROHIBITED; opt-in self-check-in only)",
      "G7": "Murakumo-only inference (commercial disaster-AI PROHIBITED)",
      "G8": "Time-bounded carve-outs (60-day initial + Council Lv7+ unanimity extension + auto-revoke on lifting)",
      "G9": "Sphere Standards minimum compliance (reference framework; silenKazaoriReview audit)",
      "G10": "Council Lv6+ ≥4/7 declaration required for emergency state",
      "G11": "NOT a state-licensed emergency services entity",
      "G12": "NO payroll for responders (vocation-flow L5 stewards)"
    }
  },
